POSTGRES_USER=pricing
POSTGRES_PASSWORD=pricing_pwd
POSTGRES_DB=pricing
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Inside docker network the host is "db"; from host machine — "localhost"
DATABASE_URL=postgresql+psycopg2://pricing:pricing_pwd@localhost:5432/pricing

# Parser settings
PARSER_MODE=demo        # demo | real
PARSER_INTERVAL_SEC=600 # how often the worker runs (10 min default)

# UI defaults
DEFAULT_USER=manager
DEFAULT_PASSWORD=manager123
