POSTGRES_USER=pricing
POSTGRES_PASSWORD=pricing_pwd
POSTGRES_DB=pricing
POSTGRES_HOST=localhost
# 5432 is often busy on Windows by a locally-installed PostgreSQL service,
# so we forward the container to 5433 on the host. Change if needed.
POSTGRES_PORT=5433

# Inside docker network the host is "db"; from host machine - "localhost"
DATABASE_URL=postgresql+psycopg2://pricing:pricing_pwd@localhost:5433/pricing

# Parser mode: demo (synthetic) | real (Wildberries+Ozon) | wildberries | ozon
PARSER_MODE=demo
# How often the parser worker runs, seconds (600 = 10 min)
PARSER_INTERVAL_SEC=600

# UI defaults
DEFAULT_USER=manager
DEFAULT_PASSWORD=manager123
